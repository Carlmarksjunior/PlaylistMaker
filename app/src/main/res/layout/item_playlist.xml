<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="?attr/colorSecondary"
    android:backgroundTint="?attr/colorSecondary"
    card_view:cardElevation="0dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="@dimen/margin4"
        >
        <ImageView
            android:id="@+id/image_view_item_album"
            android:layout_width="match_parent"
            android:layout_height="@dimen/marginTop196"
            android:background="@drawable/shape_image"
            android:clipToOutline="true"
            android:layout_marginTop="@dimen/marginSettings"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/margin4"/>
        <TextView
            android:id="@+id/tv_name_item_album"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_gravity="start"
            android:fontFamily="@font/ys_display_regular"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/smallTextSize12"
            tools:text="asdasdasd"/>
        <TextView
            android:id="@+id/tv_tracks_item_album"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_gravity="start"
            android:fontFamily="@font/ys_display_regular"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/smallTextSize12"
            tools:text="sdasdasd"/>
    </LinearLayout>

</androidx.cardview.widget.CardView>