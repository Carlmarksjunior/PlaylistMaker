<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/lightGray"
    tools:context=".ui.detailsPlayList.fragment.DetailsPlayListFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >
        <ImageView
            android:id="@+id/image_view_album"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="@color/white"
            android:padding="48dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_placeholder_360"
            />
        <ImageButton
            android:id="@+id/back_button_play_list"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"
            android:background="@null"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_back_arrow_24" />

        <TextView
            android:id="@+id/name_album_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/image_view_album"
            android:layout_marginStart="@dimen/marginSettings"
            tools:text="Best Songs 2021"
            android:textSize="@dimen/well_textSize24"
            android:textAllCaps="false"
            android:textColor="@color/blackYP"
            android:fontFamily="@font/ys_display_bold"
            />
        <TextView
            android:id="@+id/description_album_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/name_album_tv"
            android:layout_marginStart="@dimen/marginSettings"
            android:layout_marginTop="@dimen/marginTop8"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="asdasdasdasdasdassdassdassdasdssdasd"
            android:textSize="@dimen/medium_textSize18"
            android:textAllCaps="false"
            android:textColor="@color/blackYP"
            android:fontFamily="@font/ys_display_regular"
            />
        <LinearLayout
            android:id="@+id/duration_count_ll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/description_album_tv"
            android:layout_marginStart="@dimen/marginSettings"
            android:layout_marginTop="@dimen/marginTop8">
            <TextView
                android:id="@+id/duration_all_tracks_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                tools:text="300 минут"
                android:maxLines="1"
                android:ellipsize="end"
                android:textSize="@dimen/medium_textSize18"
                android:textAllCaps="false"
                android:textColor="@color/blackYP"
                android:fontFamily="@font/ys_display_regular"/>
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_point_blackyp_13"
                android:layout_gravity="center"
                android:backgroundTint="@color/blackYP"/>
            <TextView
                android:id="@+id/track_count_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                tools:text="98 треков"
                android:maxLines="1"
                android:ellipsize="end"
                android:textSize="@dimen/medium_textSize18"
                android:textAllCaps="false"
                android:textColor="@color/blackYP"
                android:fontFamily="@font/ys_display_regular"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/share_album"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/duration_count_ll"
            android:layout_marginStart="@dimen/marginSettings"
            android:layout_marginTop="@dimen/marginSettings"
            android:src="@drawable/ic_share_blackyp_24"/>
        <ImageView
            android:id="@+id/menu_album"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@id/share_album"
            app:layout_constraintTop_toBottomOf="@id/duration_count_ll"
            android:layout_marginStart="@dimen/marginSettings"
            android:layout_marginTop="@dimen/marginSettings"
            android:src="@drawable/ic_menu_playlist_24"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/standard_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:weightSum="1"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_hideable="false"
        app:behavior_peekHeight="0dp"
        app:behavior_fitToContents="false"
        app:behavior_halfExpandedRatio="0.35"
        android:orientation="vertical"
        android:background="@drawable/shape_to_bottomsheet"
        android:visibility="visible">

        <View
            android:id="@+id/top_bar"
            android:layout_width="50dp"
            android:layout_height="4dp"
            android:background="@drawable/shape_to_bottomsheet"
            android:backgroundTint="@color/viewSeparatorColor"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/marginTop8"/>


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerBottomSheet"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="@dimen/marginTop"
            android:layout_gravity="center"
            android:visibility="gone"/>
        <ImageView
            android:id="@+id/media_image_place_holder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/marginTop46"
            android:layout_gravity="center"
            android:src="@drawable/ic_not_search_result_120"
            android:visibility="visible" />
        <TextView
            android:id="@+id/tv_place_holder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/marginSettings"
            android:gravity="center"
            android:layout_gravity="center"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="@dimen/textSizePlaceHolder"
            android:fontFamily="@font/ys_display_medium"
            android:visibility="visible"
            android:text="@string/tracks_in_album_is_empty"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_hideable="true"
        app:behavior_peekHeight="0dp"
        app:behavior_fitToContents="false"
        app:behavior_halfExpandedRatio="0.5"
        android:orientation="vertical"
        android:background="@drawable/shape_to_bottomsheet"
        android:visibility="visible">

        <View
            android:layout_width="50dp"
            android:layout_height="4dp"
            android:background="@drawable/shape_to_bottomsheet"
            android:backgroundTint="@color/viewSeparatorColor"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/marginTop8"/>

        <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            xmlns:tools="http://schemas.android.com/tools"
            android:layout_height="61dp"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/marginTop"
            android:paddingLeft="@dimen/paddingLeftTrack"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:id="@+id/artAlbum"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:layout_gravity="center"
                android:background="@drawable/shape_image"
                tools:src = "@drawable/ic_launcher_background"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginLeft="8dp"
                android:layout_gravity="center_vertical">
                <TextView
                    android:id="@+id/albumNameTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Smells Like Teen Spirit"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/ys_display_regular"
                    android:textColor="?attr/colorOnPrimary"
                    android:textSize="@dimen/medium_textSize"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tracksCountTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        tools:text="Nirvana"
                        style="@style/TrackTv"/>
                </LinearLayout>
            </LinearLayout>


        </LinearLayout>
        <Button
            android:id="@+id/shareAlbumSecond"
            style="@style/settingButton"
            android:layout_marginTop="@dimen/marginTop8"
            android:text="@string/share"
            />

        <Button
            android:id="@+id/redactAlbum"
            style="@style/settingButton"
            android:paddingEnd="2dp"
            android:text="@string/redact_information"
            />
        <Button
            android:id="@+id/delete_playlist"
            style="@style/settingButton"
            android:paddingEnd="8dp"
            android:text="@string/delete_play_list"
            />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>