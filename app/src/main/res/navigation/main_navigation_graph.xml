<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_navigation_graph"
    app:startDestination="@id/mediaFragment">

    <fragment
        android:id="@+id/mediaFragment"
        android:name="com.practicum.playlistmaker.ui.media.fragments.MediaFragment"
        android:label="fragment_media"
        tools:layout="@layout/fragment_media" >
        <action
            android:id="@+id/action_mediaFragment_to_playerFragment"
            app:destination="@id/playerFragment" />
        <action
            android:id="@+id/action_mediaFragment_to_playListCreateFragment"
            app:destination="@id/playListCreateFragment" />
        <action
            android:id="@+id/action_mediaFragment_to_detailsPlayList"
            app:destination="@id/detailsPlayList" />
    </fragment>
    <fragment
        android:id="@+id/playerFragment"
        android:name="com.practicum.playlistmaker.ui.player.fragment.PlayerFragment"
        android:label="fragment_player"
        tools:layout="@layout/fragment_player" >
        <action
            android:id="@+id/action_playerFragment_to_playListCreateFragment"
            app:destination="@id/playListCreateFragment" />
        <action
            android:id="@+id/action_playerFragment_to_detailsPlayList"
            app:destination="@id/detailsPlayList" />
    </fragment>
    <fragment
        android:id="@+id/searchFragment"
        android:name="com.practicum.playlistmaker.ui.search.fragment.SearchFragment"
        android:label="fragment_search"
        tools:layout="@layout/fragment_search" >
        <action
            android:id="@+id/action_searchFragment_to_playerFragment"
            app:destination="@id/playerFragment" />
    </fragment>
    <fragment
        android:id="@+id/settingFragment"
        android:name="com.practicum.playlistmaker.ui.settings.fragments.SettingFragment"
        android:label="fragment_setting"
        tools:layout="@layout/fragment_setting" />
    <fragment
        android:id="@+id/playListCreateFragment"
        android:name="com.practicum.playlistmaker.ui.playList.fragment.PlayListCreateFragment"
        android:label="fragment_play_list_create"
        tools:layout="@layout/fragment_play_list_create" />
    <fragment
        android:id="@+id/detailsPlayList"
        android:name="com.practicum.playlistmaker.ui.detailsPlayList.fragment.DetailsPlayListFragment"
        android:label="fragment_details_play_list"
        tools:layout="@layout/fragment_details_play_list" >
        <action
            android:id="@+id/action_detailsPlayList_to_playerFragment"
            app:destination="@id/playerFragment" />
        <action
            android:id="@+id/action_detailsPlayList_to_playListRedactFragment"
            app:destination="@id/playListRedactFragment" />
    </fragment>
    <fragment
        android:id="@+id/playListRedactFragment"
        android:name="com.practicum.playlistmaker.ui.playList.fragment.PlayListRedactFragment"
        android:label="PlayListRedactFragment" />
</navigation>